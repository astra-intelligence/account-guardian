# Account Guardian — Environment Variables
# Copy this to .env and fill in the values

# --- Database ---
# Neon PostgreSQL connection string (free tier: https://console.neon.tech)
# Sign up, create a project, copy the connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Stripe (https://dashboard.stripe.com) ---
# Stripe Connect OAuth client ID (Developers > OAuth)
STRIPE_CLIENT_ID=ca_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Stripe secret key (Developers > API keys)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Stripe webhook signing secret (Developers > Webhooks, create endpoint)
# Endpoint URL: https://<your-app-url>/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# --- App ---
# Public URL (must match Stripe redirect URI)
# For Render: https://accountguardian.onrender.com
# For prod: https://accountguardian.astraintelligence.co
APP_URL=https://accountguardian.astraintelligence.co
# Express session secret (already generated)
SESSION_SECRET=c47fc26ebabb83002279ec2f4ba937d0677e4b87b805f2a4421cd009e0b3e6ba

# --- Postmark (https://account.postmarkapp.com) ---
# Transactional email for alerts, dunning, onboarding
POSTMARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Polsia (https://polsia.com) ---
# API key for email proxy (inbound/outbound support replies) and AI triage
POLSIA_API_KEY=pk_xxxxxxxxxxxxxxxxxxxx
# Polsia API base URL (default)
POLSIA_API_URL=https://polsia.com/api/proxy/ai
